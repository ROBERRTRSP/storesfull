# --- Postgres local (Docker) ---
# DATABASE_URL="postgresql://ruta:ruta@localhost:5432/ruta_dev?schema=public"
# DIRECT_URL="postgresql://ruta:ruta@localhost:5432/ruta_dev?schema=public"

# --- Neon (https://console.neon.tech) ---
# En el proyecto Neon → Connection details:
# 1) "Pooled connection" (recomendado para API en la nube / muchas conexiones cortas)
# 2) "Direct connection" (para migraciones; host sin "-pooler")
#
# DATABASE_URL = cadena con host ...-pooler... (o la directa si no usas pooler)
# DIRECT_URL   = cadena directa (sin pooler). Si no usas pooler, copia la misma URL en las dos.
#
# DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxxx-pooler.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

DATABASE_URL="postgresql://ruta:ruta@localhost:5432/ruta_dev?schema=public"
DIRECT_URL="postgresql://ruta:ruta@localhost:5432/ruta_dev?schema=public"

PORT="3010"
JWT_ACCESS_SECRET="change-me-access"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_ACCESS_TTL_SECONDS="900"
JWT_REFRESH_TTL_SECONDS="2592000"
