# API en el mismo Next: no hace falta NEXT_PUBLIC_API_URL salvo otro origen.
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# (SSR / server sin VERCEL_URL en local)

# BD y JWT: por defecto next.config carga también apps/api/.env (monorepo).
# Crea apps/web/.env.local solo si quieres valores distintos a la API o despliegues sin carpeta api.

# Neon (Vercel y local):
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

# JWT (mismos secretos que apps/api si migras desde Nest)
# JWT_ACCESS_SECRET=
# JWT_REFRESH_SECRET=
# JWT_ACCESS_TTL_SECONDS=900
# JWT_REFRESH_TTL_SECONDS=2592000

# Recuperación de contraseña (opcional; sin SMTP el enlace sale en consola del servidor en dev)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=
