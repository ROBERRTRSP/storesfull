# Opción A — desarrollo: API en tu máquina
NEXT_PUBLIC_API_URL=http://localhost:3010/api/v1

# Opción B — igual que en Vercel: proxy (sin NEXT_PUBLIC_API_URL)
# URL del Nest SIN /api/v1 (next dev necesita esto si quieres probar el proxy local)
# API_BACKEND_URL=http://localhost:3010

# Misma base que apps/api (.env). En Vercel: DATABASE_URL y DIRECT_URL (Neon: pooled + direct, o la misma URL dos veces).
# Neon ejemplo:
# DATABASE_URL="postgresql://USER:PASS@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://USER:PASS@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
